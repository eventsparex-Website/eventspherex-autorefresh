---
layout: base.njk
pagination:
  data: collections.categories
  size: 1
  alias: cat
permalink: /category/{{ cat.slug }}/
eleventyComputed:
  title: "{{ cat.name }} - EventSphereX"
---

<!-- Page Hero -->
<div class="page-hero">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <a href="/posts/">News</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{{ cat.name }}</span>
    </nav>
    <h1 class="page-hero-title">{{ cat.name }}</h1>
    <p class="page-hero-desc">Latest {{ cat.name | lower }} news and insights from India's event industry <span class="page-hero-count">{{ cat.posts | length }} articles</span></p>
  </div>
</div>

<!-- Category Tabs -->
<div class="category-tabs-wrapper">
  <div class="container">
    <div class="category-tabs">
      <a href="/posts/" class="category-tab">All</a>
      <a href="/category/exhibitions-trade-shows/" class="category-tab {% if cat.slug == 'exhibitions-trade-shows' %}active{% endif %}">Exhibitions</a>
      <a href="/category/corporate-events/" class="category-tab {% if cat.slug == 'corporate-events' %}active{% endif %}">Corporate</a>
      <a href="/category/brand-activations-launches/" class="category-tab {% if cat.slug == 'brand-activations-launches' %}active{% endif %}">Brand Activations</a>
      <a href="/category/mice-conferences/" class="category-tab {% if cat.slug == 'mice-conferences' %}active{% endif %}">MICE</a>
      <a href="/category/event-technology-innovation/" class="category-tab {% if cat.slug == 'event-technology-innovation' %}active{% endif %}">Technology</a>
      <a href="/category/weddings-social-events/" class="category-tab {% if cat.slug == 'weddings-social-events' %}active{% endif %}">Weddings</a>
      <a href="/category/industry-reports/" class="category-tab {% if cat.slug == 'industry-reports' %}active{% endif %}">Reports</a>
      <a href="/category/industry-insights/" class="category-tab {% if cat.slug == 'industry-insights' %}active{% endif %}">Insights</a>
    </div>
  </div>
</div>

<!-- Posts Archive Grid -->
<section class="section posts-archive">
  <div class="container">
    <div class="posts-archive-grid">
      {% for post in cat.posts %}
      <a href="/posts/{{ post.data.slug }}/" class="archive-card">
        <div class="archive-card-img">
          {% if post.data.featured_image %}
            <img src="{{ post.data.featured_image }}" loading="lazy" alt="{{ post.data.title }}">
          {% else %}
            <div class="archive-card-placeholder">&#128240;</div>
          {% endif %}
        </div>
        <div class="archive-card-body">
          <span class="badge {{ post.data.badgeClass }}">{{ post.data.category }}</span>
          <h3 class="archive-card-title">{{ post.data.title }}</h3>
          {% if post.data.excerpt %}
          <p class="archive-card-excerpt">{{ post.data.excerpt | truncate(120) }}</p>
          {% endif %}
          <div class="archive-card-footer">
            <div class="archive-card-author">
              <div class="author-avatar">{{ post.data.author | initials }}</div>
              <span>{{ post.data.author }}</span>
            </div>
            <span class="read-time">{{ post.templateContent | readTime }}</span>
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
