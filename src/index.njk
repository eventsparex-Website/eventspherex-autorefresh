---
layout: base.njk
title: "EventSphereX - India's #1 Event Industry Portal"
---

<!-- ===== HERO SECTION ===== -->
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      {% set heroPosts = collections.posts | limit(3) %}
      {% if heroPosts | length > 0 %}
      {% set featured = heroPosts[0] %}
      <!-- Featured Main -->
      <a href="/posts/{{ featured.data.slug }}/" class="hero-main" style="display:block">
        {% if featured.data.featured_image %}
          <img src="{{ featured.data.featured_image }}" loading="lazy" alt="{{ featured.data.title }}">
        {% else %}
          <div style="width:100%;height:100%;background:linear-gradient(135deg,#0d3d39,#091d1b)"></div>
        {% endif %}
        <div class="hero-main-content">
          <span class="badge {{ featured.data.badgeClass }}">{{ featured.data.category }}</span>
          <h2>{{ featured.data.title }}</h2>
          <p>{{ featured.data.excerpt }}</p>
          <div class="meta">
            <span>By {{ featured.data.author }}</span>
            <span>&bull;</span>
            <span>{{ featured.templateContent | readTime }}</span>
            <span>&bull;</span>
            <span>{{ featured.data.date | timeAgo }}</span>
          </div>
        </div>
      </a>

      <div class="hero-side">
        {% for post in heroPosts %}
          {% if loop.index > 1 %}
          <a href="/posts/{{ post.data.slug }}/" class="hero-card" style="display:block">
            {% if post.data.featured_image %}
              <img src="{{ post.data.featured_image }}" loading="lazy" alt="{{ post.data.title }}">
            {% else %}
              <div style="width:100%;height:100%;background:linear-gradient(135deg,#0d3d39,#091d1b)"></div>
            {% endif %}
            <div class="hero-card-content">
              <span class="badge {{ post.data.badgeClass }}">{{ post.data.category }}</span>
              <h3>{{ post.data.title }}</h3>
              <div class="meta">{{ post.templateContent | readTime }} &bull; {{ post.data.date | timeAgo }}</div>
            </div>
          </a>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
</section>

<!-- ===== MAIN CONTENT + SIDEBAR ===== -->
<section class="section" style="padding-top:20px">
  <div class="container">
    <div class="main-grid">
      <!-- Main Content -->
      <div class="main-content">
        <h2 class="section-title">Latest News <a href="/posts/">View All &rarr;</a></h2>
        <div class="article-list">
          {% set latestPosts = collections.posts | offset(3) | limit(8) %}
          {% for post in latestPosts %}
          <article class="article-card fade-in">
            <div class="article-card-img">
              <a href="/posts/{{ post.data.slug }}/">
                {% if post.data.featured_image %}
                  <img src="{{ post.data.featured_image }}" loading="lazy" alt="{{ post.data.title }}">
                {% else %}
                  <div style="width:100%;height:100%;background:var(--bg-alt);display:flex;align-items:center;justify-content:center;color:var(--text3);font-size:40px">&#128240;</div>
                {% endif %}
              </a>
            </div>
            <div class="article-card-body">
              <span class="badge {{ post.data.badgeClass }}">{{ post.data.category }}</span>
              <h3><a href="/posts/{{ post.data.slug }}/">{{ post.data.title }}</a></h3>
              <p>{{ post.data.excerpt }}</p>
              <div class="article-card-footer">
                <div class="author">
                  <div class="author-avatar">{{ post.data.author | initials }}</div>
                  <span>{{ post.data.author }} &bull; {{ post.templateContent | readTime }}</span>
                </div>
                <button class="article-bookmark" title="Bookmark">&#9734;</button>
              </div>
            </div>
          </article>
          {% endfor %}
        </div>
        <div style="text-align:center;margin-top:24px">
          <a href="/posts/" class="btn btn-outline">View All Stories &darr;</a>
        </div>
      </div>

      <!-- Sidebar -->
      {% include "sidebar.njk" %}
    </div>
  </div>
</section>

<!-- ===== CATEGORY CARDS SECTION ===== -->
<section class="category-cards-section">
  <div class="container">
    <h2 class="section-title">Explore Categories</h2>
    <div class="category-cards-grid">
      <a href="/category/exhibitions-trade-shows/" class="category-icon-card">
        <div class="category-icon-wrap">&#127978;</div>
        <h4>Exhibitions &amp; Trade Shows</h4>
        <p>Latest from India's top expos</p>
      </a>
      <a href="/category/corporate-events/" class="category-icon-card">
        <div class="category-icon-wrap">&#127970;</div>
        <h4>Corporate Events</h4>
        <p>Conferences, summits &amp; more</p>
      </a>
      <a href="/category/brand-activations-launches/" class="category-icon-card">
        <div class="category-icon-wrap">&#127775;</div>
        <h4>Brand Activations</h4>
        <p>Experiential marketing insights</p>
      </a>
      <a href="/category/mice-conferences/" class="category-icon-card">
        <div class="category-icon-wrap">&#9992;</div>
        <h4>MICE &amp; Conferences</h4>
        <p>Business travel &amp; meetings</p>
      </a>
      <a href="/category/event-technology-innovation/" class="category-icon-card">
        <div class="category-icon-wrap">&#128187;</div>
        <h4>Event Technology</h4>
        <p>AI, AR/VR &amp; digital tools</p>
      </a>
      <a href="/category/weddings-social-events/" class="category-icon-card">
        <div class="category-icon-wrap">&#128141;</div>
        <h4>Weddings &amp; Social</h4>
        <p>Trends in social celebrations</p>
      </a>
    </div>
  </div>
</section>

<!-- ===== CATEGORY: EXHIBITIONS ===== -->
{% set exhibitionPosts = [] %}
{% for post in collections.posts %}
  {% if post.data.categorySlug == "exhibitions-trade-shows" and exhibitionPosts | length < 4 %}
    {% set exhibitionPosts = (exhibitionPosts.push(post), exhibitionPosts) %}
  {% endif %}
{% endfor %}
{% if exhibitionPosts | length > 0 %}
<div class="category-section fade-in">
  <div class="container">
    <h2 class="section-title">Exhibitions &amp; Trade Shows <a href="/category/exhibitions-trade-shows/">View All &rarr;</a></h2>
    <div class="category-scroll">
      {% for post in exhibitionPosts %}
      <a href="/posts/{{ post.data.slug }}/" class="cat-card" style="display:block">
        <div class="cat-card-img">
          {% if post.data.featured_image %}
            <img src="{{ post.data.featured_image }}" loading="lazy" alt="{{ post.data.title }}">
          {% else %}
            <div style="height:160px;background:var(--bg-alt);display:flex;align-items:center;justify-content:center;color:var(--text3);font-size:40px">&#128240;</div>
          {% endif %}
        </div>
        <div class="cat-card-body">
          <span class="badge badge-exhibitions">Exhibitions</span>
          <h4>{{ post.data.title }}</h4>
          <div class="meta">{{ post.data.date | timeAgo }}</div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<!-- ===== CATEGORY: EVENT TECHNOLOGY ===== -->
{% set techPosts = [] %}
{% for post in collections.posts %}
  {% if (post.data.categorySlug == "event-technology-innovation" or post.data.categorySlug == "event-technology") and techPosts | length < 4 %}
    {% set techPosts = (techPosts.push(post), techPosts) %}
  {% endif %}
{% endfor %}
{% if techPosts | length > 0 %}
<div class="category-section fade-in">
  <div class="container">
    <h2 class="section-title">Event Technology &amp; Innovation <a href="/category/event-technology-innovation/">View All &rarr;</a></h2>
    <div class="category-scroll">
      {% for post in techPosts %}
      <a href="/posts/{{ post.data.slug }}/" class="cat-card" style="display:block">
        <div class="cat-card-img">
          {% if post.data.featured_image %}
            <img src="{{ post.data.featured_image }}" loading="lazy" alt="{{ post.data.title }}">
          {% else %}
            <div style="height:160px;background:var(--bg-alt);display:flex;align-items:center;justify-content:center;color:var(--text3);font-size:40px">&#128240;</div>
          {% endif %}
        </div>
        <div class="cat-card-body">
          <span class="badge badge-tech">Technology</span>
          <h4>{{ post.data.title }}</h4>
          <div class="meta">{{ post.data.date | timeAgo }}</div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<!-- ===== STATS BAR ===== -->
<section class="stats-bar fade-in">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-num" data-target="10000">10,000+</div>
        <div class="stat-label">Event Professionals</div>
      </div>
      <div class="stat-item">
        <div class="stat-num" data-target="500">500+</div>
        <div class="stat-label">Events Covered</div>
      </div>
      <div class="stat-item">
        <div class="stat-num" data-target="50">50+</div>
        <div class="stat-label">Cities Across India</div>
      </div>
      <div class="stat-item">
        <div class="stat-num" data-target="200">200+</div>
        <div class="stat-label">Articles Published</div>
      </div>
    </div>
  </div>
</section>

