---
layout: base.njk
---

<!-- Breadcrumb -->
<div class="post-breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <a href="/category/{{ categorySlug }}/">{{ category }}</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{{ title }}</span>
    </nav>
  </div>
</div>

<!-- Post Hero Image -->
{% if featured_image %}
<div class="post-hero-banner" style="width:100%;overflow:hidden">
  <img src="{{ featured_image }}" alt="{{ title }}" class="post-hero-img" style="width:100%;max-height:500px;object-fit:cover;display:block" loading="eager">
</div>
{% endif %}

<section class="section post-single">
  <div class="container">
    <div class="main-grid">
      <div class="main-content">
        <article class="single-article">
          <div class="article-header">
            <span class="badge {{ badgeClass }}">{{ category }}</span>
            <h1>{{ title }}</h1>
            <div class="post-meta-bar">
              <div class="post-meta-left">
                <div class="post-meta-author">
                  <div class="author-avatar">{{ author | initials }}</div>
                  <div class="post-meta-author-info">
                    <span class="post-meta-author-name">{{ author }}</span>
                    <span class="post-meta-date">{{ date | dateFormat('long') }}</span>
                  </div>
                </div>
              </div>
              <div class="post-meta-right">
                <span class="read-time">{{ content | readTime }}</span>
                <button class="post-meta-share-icon" onclick="document.querySelector('.share-buttons-bar').scrollIntoView({behavior:'smooth'})" title="Share this article">&#128279;</button>
              </div>
            </div>
          </div>

          <div class="article-content">
            {{ content | safe }}
          </div>

          <!-- Share Buttons Bar -->
          <div class="share-buttons-bar">
            <span class="share-buttons-label">Share this article</span>
            <div class="share-buttons-row">
              <a href="https://wa.me/?text={{ (title + ' https://eventspherex.com/posts/' + slug + '/') | urlencode }}" target="_blank" rel="noopener" class="share-btn-styled share-btn-whatsapp">&#9742; WhatsApp</a>
              <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://eventspherex.com/posts/{{ slug }}/" target="_blank" rel="noopener" class="share-btn-styled share-btn-linkedin">in LinkedIn</a>
              <a href="https://twitter.com/intent/tweet?url={{ ('https://eventspherex.com/posts/' + slug + '/') | urlencode }}&text={{ title | urlencode }}" target="_blank" rel="noopener" class="share-btn-styled share-btn-twitter">&#120143; Twitter</a>
              <a href="https://www.facebook.com/sharer/sharer.php?u={{ ('https://eventspherex.com/posts/' + slug + '/') | urlencode }}" target="_blank" rel="noopener" class="share-btn-styled share-btn-facebook">f Facebook</a>
              <button class="share-btn-styled share-btn-copy" onclick="navigator.clipboard.writeText(window.location.href).then(()=>{this.textContent='Copied!';setTimeout(()=>{this.textContent='&#128279; Copy Link'},2000)})">&#128279; Copy Link</button>
            </div>
          </div>
        </article>

        <!-- Related Posts -->
        {% set relatedPosts = [] %}
        {% for post in collections.posts %}
          {% if post.data.categorySlug == categorySlug and post.data.slug != slug %}
            {% if relatedPosts | length < 3 %}
              {% set relatedPosts = (relatedPosts.push(post), relatedPosts) %}
            {% endif %}
          {% endif %}
        {% endfor %}

        {% if relatedPosts | length > 0 %}
        <div class="related-posts">
          <div class="section-title">Related Articles</div>
          <div class="related-posts-grid">
            {% for post in relatedPosts %}
            <a href="/posts/{{ post.data.slug }}/" class="related-post-card">
              <div class="related-post-card-img">
                {% if post.data.featured_image %}
                  <img src="{{ post.data.featured_image }}" loading="lazy" alt="{{ post.data.title }}">
                {% else %}
                  <div class="related-post-placeholder">&#128240;</div>
                {% endif %}
              </div>
              <div class="related-post-card-body">
                <span class="badge {{ post.data.badgeClass }}">{{ post.data.category }}</span>
                <h4>{{ post.data.title }}</h4>
                <div class="related-post-meta">
                  <span>{{ post.data.author }}</span>
                  <span>{{ post.data.date | timeAgo }}</span>
                </div>
              </div>
            </a>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </div>

      <!-- Sidebar -->
      {% include "sidebar.njk" %}
    </div>
  </div>
</section>
