<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} - EventSphereX{% else %}EventSphereX - India's Event Industry Portal{% endif %}</title>
<meta name="description" content="{{ description or excerpt or "India's leading event industry portal — news, insights, tools & jobs for event professionals." }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@EventSphereX">
<meta name="twitter:title" content="{{ title or "EventSphereX - India's Event Industry Portal" }}">
<meta name="twitter:description" content="{{ excerpt or "India's leading event industry portal — news, insights, tools & jobs for event professionals." }}">
{% if featured_image %}<meta name="twitter:image" content="{{ featured_image }}">{% endif %}
<meta property="og:title" content="{{ title or "EventSphereX - India's Event Industry Portal" }}">
<meta property="og:description" content="{{ excerpt or "India's leading event industry portal — news, insights, tools & jobs for event professionals." }}">
<meta property="og:type" content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}">
<meta property="og:url" content="https://eventspherex.com{{ page.url }}">
{% if featured_image %}<meta property="og:image" content="{{ featured_image }}">{% endif %}
<link rel="canonical" href="https://eventspherex.com{{ page.url }}">
<link rel="stylesheet" href="/css/style.css">
<link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#b3d237">
<meta name="google-site-verification" content="yemXUJjCt4-Suj_S7TUWmxSSytlVvF40KsJBzTzIk_o">
{% if not featured_image %}<meta property="og:image" content="https://eventspherex.com/images/og-banner.png">{% endif %}
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"Organization","name":"EventSphereX","url":"https://eventspherex.com","logo":"https://eventspherex.com/images/logo.svg","description":"India's Event Industry Portal","sameAs":["https://www.linkedin.com/company/eventspherex/","https://www.instagram.com/event_spherex/","https://www.youtube.com/@EventspareX"]}
</script>
</head>
<body>

<!-- Scroll Progress Bar -->
<div id="progress-bar"></div>

{% include "header.njk" %}

{{ content | safe }}

{% include "footer.njk" %}

<!-- Back to top -->
<button class="back-to-top" id="back-to-top">&uarr;</button>

<script src="/js/theme.js"></script>
</body>
</html>
