---
layout: base.njk
---

<style>
/* Featured Article Styles */
.featured-article-wrap {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 8px 40px rgba(0,0,0,0.08);
}

.featured-hero-image {
  width: 100%;
  height: 450px;
  object-fit: cover;
  display: block;
}

.featured-article-header {
  padding: 50px 60px 30px;
}

.featured-article-category {
  display: inline-block;
  background: rgba(179, 210, 55, 0.15);
  color: #0d3d39;
  font-size: 12px;
  font-weight: 700;
  padding: 6px 16px;
  border-radius: 50px;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 20px;
}

.featured-article-title {
  font-size: 40px;
  font-weight: 800;
  color: #091d1b;
  line-height: 1.15;
  letter-spacing: -1px;
  margin-bottom: 16px;
}

.featured-article-meta {
  font-size: 14px;
  color: #999;
  display: flex;
  gap: 20px;
  padding-bottom: 30px;
  border-bottom: 1px solid #eee;
}

.featured-article-content {
  padding: 40px 60px 60px;
  font-size: 17px;
  line-height: 1.8;
  color: #444;
}

.featured-article-content h2 {
  font-size: 28px;
  font-weight: 700;
  color: #091d1b;
  margin: 40px 0 16px;
  letter-spacing: -0.5px;
}

.featured-article-content h3 {
  font-size: 22px;
  font-weight: 700;
  color: #0d3d39;
  margin: 30px 0 12px;
}

.featured-article-content p {
  margin-bottom: 18px;
}

.featured-article-content ul,
.featured-article-content ol {
  margin: 12px 0 20px 24px;
}

.featured-article-content li {
  margin-bottom: 8px;
}

.featured-article-content strong {
  color: #091d1b;
}

.featured-article-content blockquote {
  border-left: 4px solid #b3d237;
  padding: 16px 24px;
  margin: 24px 0;
  background: #f8f9fa;
  border-radius: 0 8px 8px 0;
  font-style: italic;
  color: #555;
}

.featured-article-content hr {
  border: none;
  height: 1px;
  background: #eee;
  margin: 40px 0;
}

.featured-article-content a {
  color: #0d3d39;
  font-weight: 600;
  text-decoration: underline;
}

.featured-article-content a:hover {
  color: #b3d237;
}

/* Lead paragraph */
.lead {
  font-size: 19px;
  line-height: 1.85;
  color: #333;
  font-weight: 400;
}

/* Stats row */
.stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin: 30px 0;
}

.stat-card {
  background: #f8f9fa;
  border-radius: 12px;
  padding: 24px;
  text-align: center;
  border: 1px solid #eee;
}

.stat-card .value {
  font-size: 32px;
  font-weight: 800;
  color: #091d1b;
}

.stat-card .label {
  font-size: 13px;
  color: #999;
  margin-top: 4px;
}

/* Photo gallery */
.photo-gallery {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin: 30px 0;
}

.photo-gallery figure {
  margin: 0;
}

.photo-gallery img {
  width: 100%;
  height: 240px;
  object-fit: cover;
  border-radius: 12px;
}

.photo-gallery .full-width {
  grid-column: 1 / -1;
}

.photo-gallery .full-width img {
  height: 350px;
}

.photo-caption {
  font-size: 13px;
  color: #999;
  text-align: center;
  margin-top: 4px;
  font-style: italic;
}

/* Highlight box - dark background, override all child colors */
.highlight-box {
  background: linear-gradient(135deg, #091d1b 0%, #0d3d39 100%);
  border-radius: 12px;
  padding: 35px 40px;
  margin: 30px 0;
  color: #fff;
}

.highlight-box h3 {
  color: #b3d237 !important;
  margin-top: 0 !important;
}

.highlight-box p {
  color: rgba(255,255,255,0.7) !important;
}

.highlight-box ul {
  color: rgba(255,255,255,0.8) !important;
}

.highlight-box li {
  color: rgba(255,255,255,0.8) !important;
}

.highlight-box strong {
  color: #b3d237 !important;
}

/* Alumni grid */
.alumni-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin: 20px 0;
}

.alumni-tag {
  background: #f0f0f0;
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  color: #555;
}

/* CTA box - Technology Partner */
.cta-box {
  background: linear-gradient(135deg, #0a1628 0%, #0f2035 100%);
  border-radius: 12px;
  padding: 40px;
  text-align: center;
  margin: 40px 0 0;
}

.cta-box .cta-label {
  font-size: 11px;
  color: #00aeef;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.cta-box .cta-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.cta-box .cta-logo img {
  height: 60px;
}

.cta-box p {
  color: rgba(255,255,255,0.6) !important;
  margin-bottom: 16px;
  font-size: 13px;
  line-height: 1.6;
}

.cta-box a.cta-btn {
  display: inline-block;
  background: #00aeef;
  color: #fff !important;
  font-weight: 700;
  padding: 10px 24px;
  border-radius: 8px;
  text-decoration: none !important;
  font-size: 13px;
}

.cta-box a.cta-btn:hover {
  opacity: 0.9;
}

/* Featured section */
.featured-on-epx {
  padding: 30px 0;
}

.featured-on-epx h3 {
  color: #091d1b;
}

/* Share bar for featured */
.featured-share-bar {
  background: #fff;
  border-radius: 16px;
  padding: 30px 40px;
  box-shadow: 0 8px 40px rgba(0,0,0,0.08);
  text-align: center;
  margin-top: 30px;
}

.featured-share-bar .share-buttons-label {
  display: block;
  margin-bottom: 16px;
  font-weight: 700;
  color: #091d1b;
}

/* Responsive */
@media (max-width: 1024px) {
  .featured-article-header {
    padding: 40px 40px 24px;
  }
  .featured-article-content {
    padding: 30px 40px 50px;
  }
}

@media (max-width: 768px) {
  .featured-article-header {
    padding: 30px 24px 20px;
  }
  .featured-article-content {
    padding: 24px 24px 40px;
  }
  .featured-article-title {
    font-size: 28px;
  }
  .stats-row {
    grid-template-columns: repeat(2, 1fr);
  }
  .photo-gallery {
    grid-template-columns: 1fr;
  }
  .photo-gallery .full-width img {
    height: 240px;
  }
  .highlight-box {
    padding: 24px;
  }
  .featured-share-bar {
    padding: 24px;
  }
  .featured-hero-image {
    height: 280px;
  }
}

@media (max-width: 480px) {
  .stats-row {
    grid-template-columns: 1fr;
  }
  .featured-article-title {
    font-size: 24px;
  }
  .stat-card .value {
    font-size: 26px;
  }
}
</style>

<!-- Breadcrumb -->
<div class="post-breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <a href="/category/{{ categorySlug or 'education' }}/">{{ category }}</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{{ title }}</span>
    </nav>
  </div>
</div>

<!-- Post Hero Image - Full Width -->
{% if featured_image %}
<div class="post-hero-banner" style="width:100%;overflow:hidden">
  <img src="{{ featured_image }}" alt="{{ imageAlt or title }}" class="post-hero-img" style="width:100%;max-height:500px;object-fit:cover;object-position:center 30%;display:block" loading="eager">
</div>
{% endif %}

<!-- Main Layout with Sidebar -->
<section class="section post-single">
  <div class="container">
    <div class="main-grid">
      <div class="main-content">
        <!-- Featured Article Card -->
        <div class="featured-article-wrap">
          <div class="featured-article-header">
            <span class="featured-article-category">{{ category }}</span>
            <h1 class="featured-article-title">{{ title }}</h1>
            <div class="featured-article-meta">
              <span>By {{ author }}</span>
              <span>{{ readTime }}</span>
              <span>{{ date | dateFormat('long') }}</span>
            </div>
          </div>

          <div class="featured-article-content">
            {{ content | safe }}
          </div>
        </div>

        <!-- Share Buttons Bar -->
        <div class="featured-share-bar">
          <span class="share-buttons-label">Share this article</span>
          <div class="share-buttons-row">
            <a href="https://wa.me/?text={{ (title + ' https://eventspherex.com/posts/' + slug + '/') | urlencode }}" target="_blank" rel="noopener" class="share-btn-styled share-btn-whatsapp">&#9742; WhatsApp</a>
            <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://eventspherex.com/posts/{{ slug }}/" target="_blank" rel="noopener" class="share-btn-styled share-btn-linkedin">in LinkedIn</a>
            <a href="https://twitter.com/intent/tweet?url={{ ('https://eventspherex.com/posts/' + slug + '/') | urlencode }}&text={{ title | urlencode }}" target="_blank" rel="noopener" class="share-btn-styled share-btn-twitter">&#120143; Twitter</a>
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ ('https://eventspherex.com/posts/' + slug + '/') | urlencode }}" target="_blank" rel="noopener" class="share-btn-styled share-btn-facebook">f Facebook</a>
            <button class="share-btn-styled share-btn-copy" onclick="navigator.clipboard.writeText(window.location.href).then(()=>{this.textContent='Copied!';setTimeout(()=>{this.textContent='&#128279; Copy Link'},2000)})">&#128279; Copy Link</button>
          </div>
        </div>

        <!-- Related Posts -->
        {% set relatedPosts = [] %}
        {% for post in collections.posts %}
          {% if post.data.categorySlug == categorySlug and post.data.slug != slug %}
            {% if relatedPosts | length < 3 %}
              {% set relatedPosts = (relatedPosts.push(post), relatedPosts) %}
            {% endif %}
          {% endif %}
        {% endfor %}

        {% if relatedPosts | length > 0 %}
        <div class="related-posts">
          <div class="section-title">Related Articles</div>
          <div class="related-posts-grid">
            {% for post in relatedPosts %}
            <a href="/posts/{{ post.data.slug }}/" class="related-post-card">
              <div class="related-post-card-img">
                {% if post.data.featured_image %}
                  <img src="{{ post.data.featured_image }}" loading="lazy" alt="{{ post.data.title }}">
                {% else %}
                  <div class="related-post-placeholder">&#128240;</div>
                {% endif %}
              </div>
              <div class="related-post-card-body">
                <span class="badge {{ post.data.badgeClass }}">{{ post.data.category }}</span>
                <h4>{{ post.data.title }}</h4>
                <div class="related-post-meta">
                  <span>{{ post.data.author }}</span>
                  <span>{{ post.data.date | timeAgo }}</span>
                </div>
              </div>
            </a>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </div>

      <!-- Sidebar -->
      {% include "sidebar.njk" %}
    </div>
  </div>
</section>
