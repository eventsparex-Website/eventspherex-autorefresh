<script>
// Dropdown toggle using display:none/block
(function(){
  var toggles = document.querySelectorAll('.nav-dropdown-toggle');
  for(var i=0;i<toggles.length;i++){
    toggles[i].addEventListener('click', function(e){
      e.preventDefault();
      e.stopPropagation();
      var dd = this.nextElementSibling;
      if(!dd) return;
      var isOpen = dd.style.display === 'block';
      // Close all
      var allDD = document.querySelectorAll('.nav-dropdown');
      for(var j=0;j<allDD.length;j++) allDD[j].style.display = 'none';
      // Toggle
      if(!isOpen) dd.style.display = 'block';
    });
  }
  document.addEventListener('click', function(e){
    if(!e.target.closest('.nav-dropdown') && !e.target.closest('.nav-dropdown-toggle')){
      var allDD = document.querySelectorAll('.nav-dropdown');
      for(var j=0;j<allDD.length;j++) allDD[j].style.display = 'none';
    }
  });
})();
</script>

